{
  "name": "accel-gpu",
  "version": "0.2.3",
  "description": "NumPy for the browser GPU — zero shaders, zero dependencies",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "webgpu",
    "gpu",
    "compute",
    "numpy",
    "tensor",
    "browser",
    "inference",
    "machine-learning",
    "matrix"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Phantasm0009/accel-gpu.git"
  },
  "homepage": "https://phantasm0009.github.io/accel-gpu/",
  "license": "MIT",
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "build:site": "npm run build && node scripts/build-site.js",
    "test": "npm run build && node scripts/test.mjs",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@webgpu/types": "^0.1.69",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
